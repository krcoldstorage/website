---
type Props = {
    title: string;
    description: string;
    url?: string;
};

const { title, description, url } = Astro.props;
---

<a
    href={url}
    target="_blank"
    class="block rounded-xl border border-zinc-800 bg-zinc-900 p-6 transition-all hover:scale-[1.02] hover:border-blue-300"
>
    <div class="flex items-center justify-between mb-3">
        <h2 class="text-xl font-semibold">
            {title}
        </h2>
    </div>
    <p class="text-zinc-400 mb-4">
        {description}
    </p>
</a>
